# ============================================================
# Novel-to-Script 后端环境变量
# 复制此文件为 .env 并填入真实值
# ============================================================

# 默认 AI 提供商: anthropic | openai | deepseek | openrouter | custom
DEFAULT_AI_PROVIDER=deepseek

# 默认 API Key — 用于规则模式下不需要用户手动输入的场景
# DeepSeek: https://platform.deepseek.com/api_keys
# Anthropic: https://console.anthropic.com/
# OpenAI: https://platform.openai.com/api-keys
# OpenRouter: https://openrouter.ai/keys
DEFAULT_AI_API_KEY=sk-your-deepseek-key-here

# 默认模型名
DEFAULT_AI_MODEL=deepseek-chat

# 默认 base_url — 每个 provider 有内置默认值，此处可覆盖
# Anthropic 默认: https://api.anthropic.com
# DeepSeek 默认: https://api.deepseek.com
# OpenAI 默认: https://api.openai.com/v1
# OpenRouter 默认: https://openrouter.ai/api/v1
# DEFAULT_AI_BASE_URL=http://localhost:11434/v1

# CORS 允许的前端地址
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
